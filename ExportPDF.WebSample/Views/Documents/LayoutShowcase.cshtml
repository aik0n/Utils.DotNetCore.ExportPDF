@model LayoutShowcaseModel

@{
    ViewData["Title"] = "Layout Showcase";
}

@section Styles {
    <link rel="stylesheet" href="~/css/layout-showcase.css" />
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">@Model.Title</h1>
        <p class="text-muted mb-0">Two-column layouts, tabs, watermark, and background image</p>
    </div>
    <form asp-controller="Documents" asp-action="LayoutShowcase" method="post" class="d-flex align-items-center gap-3">
        <input type="hidden" name="cacheKey" value="@ViewData["CacheKey"]" />
        <div class="d-flex align-items-center gap-2">
            <div class="form-check mb-0">
                <input class="form-check-input" type="radio" name="isLandscape" id="orientPortrait" value="false" checked />
                <label class="form-check-label" for="orientPortrait">Portrait</label>
            </div>
            <div class="form-check mb-0">
                <input class="form-check-input" type="radio" name="isLandscape" id="orientLandscape" value="true" />
                <label class="form-check-label" for="orientLandscape">Landscape</label>
            </div>
        </div>
        <button type="submit" class="btn btn-success">&#x2193; Export to PDF</button>
    </form>
</div>

@if (Model.ShowWatermark)
{
    <div class="alert alert-warning d-inline-block mb-3">
        <strong>Watermark:</strong> "<code>@Model.WatermarkText</code>" will appear as a diagonal overlay in the PDF.
    </div>
}

@await Html.PartialAsync("_LayoutShowcasePartial", Model)
