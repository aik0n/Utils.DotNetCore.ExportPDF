@model InvoiceModel

@{
    ViewData["Title"] = "Invoice CSS Only";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Invoice <span class="text-muted fs-4">#@Model.InvoiceNumber</span></h1>
        <p class="text-muted mb-0">Preview of the invoice document - plain CSS, Stress Testing</p>
    </div>
    <div class="d-flex align-items-center gap-2">
        <form asp-controller="Documents" asp-action="InvoiceCss" method="get" class="d-flex align-items-center gap-2">
            <input type="number" name="numberOfRows" value="@ViewData["NumberOfRows"]" min="1" class="form-control" style="width:120px" />
            <button type="submit" class="btn btn-secondary">Regenerate</button>
        </form>
        <form asp-controller="Documents" asp-action="InvoiceCss" method="post">
            <input type="hidden" name="cacheKey" value="@ViewData["CacheKey"]" />
            <button type="submit" class="btn btn-success">&#x2193; Export to PDF</button>
        </form>
    </div>
</div>

@await Html.PartialAsync("_InvoiceCssPartial", Model)
