@model InvoiceModel

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header text-uppercase small text-muted fw-semibold">From</div>
            <div class="card-body">
                <p class="mb-1 fw-bold">@Model.BillFrom.Name</p>
                <p class="mb-1 text-muted small">@Model.BillFrom.Address</p>
                <p class="mb-0 text-muted small">@Model.BillFrom.Email</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header text-uppercase small text-muted fw-semibold">Bill To</div>
            <div class="card-body">
                <p class="mb-1 fw-bold">@Model.BillTo.Name</p>
                <p class="mb-1 text-muted small">@Model.BillTo.Address</p>
                <p class="mb-0 text-muted small">@Model.BillTo.Email</p>
            </div>
        </div>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <span class="text-muted small">Issued:</span>
        <span class="fw-semibold">@Model.IssueDate.ToString("MMMM d, yyyy")</span>
    </div>
    <div class="col-md-4">
        <span class="text-muted small">Due:</span>
        <span class="fw-semibold">@Model.DueDate.ToString("MMMM d, yyyy")</span>
    </div>
</div>

<table class="table table-bordered table-hover">
    <thead class="table-primary">
        <tr>
            <th>Description</th>
            <th class="text-end">Qty</th>
            <th class="text-end">Unit Price</th>
            <th class="text-end">Total</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.Description</td>
                <td class="text-end">@item.Quantity</td>
                <td class="text-end">$@item.UnitPrice.ToString("N2")</td>
                <td class="text-end">$@item.Total.ToString("N2")</td>
            </tr>
        }
    </tbody>
</table>

<div class="d-flex justify-content-end mb-4">
    <table class="table table-sm" style="width: 300px;">
        <tbody>
            <tr>
                <td class="text-muted">Subtotal</td>
                <td class="text-end">$@Model.Subtotal.ToString("N2")</td>
            </tr>
            <tr>
                <td class="text-muted">Tax (@((Model.TaxRate * 100).ToString("0"))%)</td>
                <td class="text-end">$@Model.TaxAmount.ToString("N2")</td>
            </tr>
            <tr class="fw-bold border-top">
                <td>Grand Total</td>
                <td class="text-end">$@Model.GrandTotal.ToString("N2")</td>
            </tr>
        </tbody>
    </table>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Notes))
{
    <div class="alert alert-info">
        <strong>Notes</strong><br />
        @Model.Notes
    </div>
}
