@model LayoutShowcaseModel

@{
    ViewData["Title"] = "Layout Showcase";
}

@section Styles {
    <style>
        .content { position: relative; }
        .page-title {
            font-size: 24px; font-weight: 700; color: #4a90d9;
            border-bottom: 3px solid #4a90d9; padding-bottom: 12px;
            margin-bottom: 28px;
        }
        .columns { display: flex; gap: 24px; margin-bottom: 36px; }
        .col { flex: 1; }
        .col-heading {
            font-size: 11px; text-transform: uppercase; letter-spacing: 1px;
            color: #fff; background: #4a90d9; padding: 6px 12px;
            border-radius: 4px 4px 0 0;
        }
        .col-body {
            border: 1px solid #c8ddf5; border-top: none;
            border-radius: 0 0 4px 4px; padding: 14px;
            font-size: 12.5px; line-height: 1.6; color: #333;
            background: #f7faff;
        }
        .tabs-section { margin-bottom: 36px; }
        .tabs-section h3 {
            font-size: 13px; font-weight: 700; color: #1a1a2e;
            margin-bottom: 12px;
        }
        .tab-panel {
            border: 1px solid #c8ddf5; border-radius: 6px;
            margin-bottom: 10px; overflow: hidden;
        }
        .tab-label {
            background: #4a90d9; color: #fff;
            padding: 7px 14px; font-size: 11px; font-weight: 600;
            letter-spacing: 0.5px;
        }
        .tab-content-inner {
            padding: 12px 14px; font-size: 12.5px; line-height: 1.55;
            color: #333; background: #fff;
        }
        .tab-panel.active .tab-label { background: #1b6ec2; }
        .tab-panel.active .tab-content-inner { background: #f0f6ff; }
    </style>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">@Model.Title</h1>
        <p class="text-muted mb-0">Two-column layouts, tabs, watermark, and background image</p>
    </div>
    <form asp-controller="Documents" asp-action="LayoutShowcaseShow" method="post">
        <input type="hidden" name="cacheKey" value="@ViewData["CacheKey"]" />
        <button type="submit" class="btn btn-success">&#x2193; Export to PDF</button>
    </form>
</div>

@if (Model.ShowWatermark)
{
    <div class="alert alert-warning d-inline-block mb-3">
        <strong>Watermark:</strong> "<code>@Model.WatermarkText</code>" will appear as a diagonal overlay in the PDF.
    </div>
}

@await Html.PartialAsync("_LayoutShowcasePartial", Model)
