@model LayoutShowcaseModel
@{
    ViewData["Title"] = "Layout Showcase";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">@Model.Title</h1>
        <p class="text-muted mb-0">Two-column layouts, tabs, watermark, and background image</p>
    </div>
    <a asp-controller="Documents" asp-action="LayoutShowcaseExport" class="btn btn-success">
        &#x2193; Export to PDF
    </a>
</div>

@if (Model.ShowWatermark)
{
    <div class="alert alert-warning d-inline-block mb-3">
        <strong>Watermark:</strong> "<code>@Model.WatermarkText</code>" will appear as a diagonal overlay in the PDF.
    </div>
}

<h5 class="mb-3">Two-Column Layout</h5>
<div class="row mb-4">
    <div class="col-md-6">
        <div class="card h-100 border-primary">
            <div class="card-header bg-primary text-white">@Model.LeftColumn.Heading</div>
            <div class="card-body">
                <p>@Model.LeftColumn.Body</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100 border-secondary">
            <div class="card-header bg-secondary text-white">@Model.RightColumn.Heading</div>
            <div class="card-body">
                <p>@Model.RightColumn.Body</p>
            </div>
        </div>
    </div>
</div>

<h5 class="mb-3">Tab Panels</h5>
<ul class="nav nav-tabs mb-3" role="tablist">
    @for (int i = 0; i < Model.Tabs.Count; i++)
    {
        var tab = Model.Tabs[i];
        var tabId = $"tab-{i}";
        <li class="nav-item" role="presentation">
            <button class="nav-link @(tab.IsActive ? "active" : "")"
                    id="@tabId-btn"
                    data-bs-toggle="tab"
                    data-bs-target="#@tabId"
                    type="button"
                    role="tab">@tab.Label</button>
        </li>
    }
</ul>
<div class="tab-content border border-top-0 p-3 rounded-bottom mb-4">
    @for (int i = 0; i < Model.Tabs.Count; i++)
    {
        var tab = Model.Tabs[i];
        var tabId = $"tab-{i}";
        <div class="tab-pane fade @(tab.IsActive ? "show active" : "")" id="@tabId" role="tabpanel">
            <p class="mb-0">@tab.Content</p>
        </div>
    }
</div>

<div class="alert alert-info">
    <strong>PDF note:</strong> In the exported PDF, tabs are rendered as stacked panels (JavaScript interactivity is not available in Puppeteer's headless environment).
</div>
