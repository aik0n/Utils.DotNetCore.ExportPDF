@model PartialViewModel
@{
    ViewData["Title"] = "Partial Views & Composition";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">@Model.Title</h1>
        <p class="text-muted mb-0">Shared header/footer, conditional sections, page orientation</p>
    </div>
    <a asp-controller="Documents" asp-action="PartialViewsExport" class="btn btn-success">
        &#x2193; Export to PDF
    </a>
</div>

@if (Model.IsLandscape)
{
    <div class="badge bg-info text-dark mb-3">Landscape orientation</div>
}

<div class="card mb-3 border-primary">
    <div class="card-header bg-primary text-white d-flex justify-content-between">
        <span>@Model.Header.CompanyName</span>
        <span>@Model.Header.DocumentTitle</span>
        <span class="small opacity-75">Generated: @Model.Header.GeneratedAt.ToString("yyyy-MM-dd HH:mm") UTC</span>
    </div>
    <div class="card-body p-0">

        @foreach (var sec in Model.Sections)
        {
            <div class="p-3 border-bottom @(sec.IsHighlighted ? "bg-warning bg-opacity-25" : "")">
                <h6 class="fw-semibold mb-1">
                    @sec.SectionTitle
                    @if (sec.IsHighlighted)
                    {
                        <span class="badge bg-warning text-dark ms-2">Highlighted</span>
                    }
                </h6>
                <p class="mb-0 text-muted small">@sec.Body</p>
            </div>
        }

    </div>
    <div class="card-footer text-muted d-flex justify-content-between small">
        <span>@Model.Footer.ConfidentialityNote</span>
        <span>Page @Model.Footer.PageNumber</span>
    </div>
</div>

<div class="alert alert-info">
    <strong>PDF composition note:</strong> In the exported PDF, the shared header and footer are rendered via <code>@@functions</code> helpers defined in the template, demonstrating reusable component composition within a self-contained Razor template.
</div>
