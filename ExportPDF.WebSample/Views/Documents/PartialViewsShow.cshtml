@model PartialViewModel

@{
    ViewData["Title"] = "Partial Views & Composition";
}

@section Styles {
    <style>
        .doc-header {
            display: flex; justify-content: space-between; align-items: flex-end;
            border-bottom: 3px solid #4a90d9; padding-bottom: 14px;
            margin-bottom: 28px;
        }
        .doc-header .company { font-size: 20px; font-weight: 700; color: #4a90d9; }
        .doc-header .doc-title { font-size: 16px; font-weight: 600; color: #1a1a2e; }
        .doc-header .generated { font-size: 10px; color: #888; }

        .section {
            border: 1px solid #dde6f0; border-radius: 6px;
            padding: 14px 16px; margin-bottom: 14px; background: #fff;
        }
        .section.highlighted { background: #fffde7; border-color: #f5c542; }
        .section-title {
            font-size: 13px; font-weight: 700; margin-bottom: 6px; color: #1a1a2e;
        }
        .section-title .badge {
            display: inline-block; font-size: 9px; padding: 2px 6px;
            background: #f5c542; color: #1a1a2e; border-radius: 3px;
            margin-left: 8px; vertical-align: middle; font-weight: 600;
        }
        .section-body { font-size: 12.5px; line-height: 1.6; color: #444; }

        .doc-footer {
            margin-top: 36px; border-top: 1px solid #e0e0e0; padding-top: 12px;
            display: flex; justify-content: space-between;
            font-size: 10px; color: #999;
        }
    </style>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">@Model.Title</h1>
        <p class="text-muted mb-0">Shared header/footer, conditional sections, page orientation</p>
    </div>
    <form asp-controller="Documents" asp-action="PartialViewsShow" method="post">
        <input type="hidden" name="cacheKey" value="@ViewData["CacheKey"]" />
        <button type="submit" class="btn btn-success">&#x2193; Export to PDF</button>
    </form>
</div>

@if (Model.IsLandscape)
{
    <div class="badge bg-info text-dark mb-3">Landscape orientation</div>
}

@await Html.PartialAsync("_PartialViewsPartial", Model)
