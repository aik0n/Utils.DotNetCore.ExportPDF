@model ExportPDF.WebSample.Models.PartialViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 13px;
               color: #1a1a2e; background: #fff;
               @Html.Raw(Model.IsLandscape ? "padding: 30px 60px;" : "padding: 40px 50px;") }

        /* ── Shared header component ────────────────────────── */
        .doc-header {
            display: flex; justify-content: space-between; align-items: flex-end;
            border-bottom: 3px solid #4a90d9; padding-bottom: 14px;
            margin-bottom: 28px;
        }
        .doc-header .company { font-size: 20px; font-weight: 700; color: #4a90d9; }
        .doc-header .doc-title { font-size: 16px; font-weight: 600; color: #1a1a2e; }
        .doc-header .generated { font-size: 10px; color: #888; }

        /* ── Section ────────────────────────────────────────── */
        .section {
            border: 1px solid #dde6f0; border-radius: 6px;
            padding: 14px 16px; margin-bottom: 14px;
            background: #fff;
        }
        .section.highlighted { background: #fffde7; border-color: #f5c542; }
        .section-title {
            font-size: 13px; font-weight: 700; margin-bottom: 6px; color: #1a1a2e;
        }
        .section-title .badge {
            display: inline-block; font-size: 9px; padding: 2px 6px;
            background: #f5c542; color: #1a1a2e; border-radius: 3px;
            margin-left: 8px; vertical-align: middle; font-weight: 600;
        }
        .section-body { font-size: 12.5px; line-height: 1.6; color: #444; }

        /* ── Shared footer component ────────────────────────── */
        .doc-footer {
            margin-top: 36px; border-top: 1px solid #e0e0e0; padding-top: 12px;
            display: flex; justify-content: space-between;
            font-size: 10px; color: #999;
        }
    </style>
</head>
<body>

    @{ RenderDocHeader(Model.Header); }

    @foreach (var sec in Model.Sections)
    {
        <div class="section @(sec.IsHighlighted ? "highlighted" : "")">
            <div class="section-title">
                @sec.SectionTitle
                @if (sec.IsHighlighted)
                {
                    <span class="badge">HIGHLIGHTED</span>
                }
            </div>
            <div class="section-body">@sec.Body</div>
        </div>
    }

    @{ RenderDocFooter(Model.Footer); }

</body>
</html>

@functions {
    void RenderDocHeader(ExportPDF.WebSample.Models.DocumentHeader h)
    {
        <div class="doc-header">
            <div class="company">@h.CompanyName</div>
            <div class="doc-title">@h.DocumentTitle</div>
            <div class="generated">Generated: @h.GeneratedAt.ToString("yyyy-MM-dd HH:mm") UTC</div>
        </div>
    }

    void RenderDocFooter(ExportPDF.WebSample.Models.DocumentFooter f)
    {
        <div class="doc-footer">
            <span>@f.ConfidentialityNote</span>
            <span>Page @f.PageNumber</span>
        </div>
    }
}
