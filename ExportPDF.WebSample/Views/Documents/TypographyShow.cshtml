@model TypographyModel

@{
    ViewData["Title"] = "Typography & Fonts";
}


<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">@Model.Title</h1>
        <p class="text-muted mb-0">Custom fonts, Unicode, long text, and print CSS</p>
    </div>
    <form asp-controller="Documents" asp-action="TypographyShow" method="post">
        <input type="hidden" name="cacheKey" value="@ViewData["CacheKey"]" />
        <button type="submit" class="btn btn-success">&#x2193; Export to PDF</button>
    </form>
</div>

@await Html.PartialAsync("_TypographyPartial", Model)
