@model ExportPDF.WebSample.Models.TypographyModel

@{
    Layout = null;
}

<!DOCTYPE HTML>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Merriweather:ital,wght@@0,400;0,700;1,400&family=Source+Code+Pro&display=swap');

        @@font-face {
            font-family: 'ShowcaseSerif';
            src: local('Georgia'), local('Times New Roman');
            font-weight: normal;
        }

        @@media print {
            .screen-only { display: none !important; }
            body { color: #000 !important; background: #fff !important; }
            .print-highlight { background: #fffde7 !important; }
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 13px;
               color: #1a1a2e; background: #fff; padding: 40px 50px; }

        .page-title {
            font-size: 24px; font-weight: 700; color: #4a90d9;
            border-bottom: 3px solid #4a90d9; padding-bottom: 12px;
            margin-bottom: 28px;
        }

        .section-heading {
            font-size: 11px; text-transform: uppercase; letter-spacing: 1px;
            color: #4a90d9; margin-bottom: 10px; margin-top: 24px;
        }

        .font-sample {
            border: 1px solid #dde6f0; border-radius: 6px;
            padding: 10px 14px; margin-bottom: 10px; background: #f7faff;
        }
        .font-meta { font-size: 10px; color: #888; margin-bottom: 4px; }
        .font-preview { font-size: 15px; line-height: 1.4; }

        .unicode-block {
            font-size: 20px; letter-spacing: 3px; padding: 14px 18px;
            background: #f0f6ff; border-radius: 6px; border-left: 4px solid #4a90d9;
            margin-bottom: 16px;
        }

        .long-para {
            font-size: 12.5px; line-height: 1.7; color: #333;
            word-wrap: break-word; overflow-wrap: break-word;
            text-align: justify;
        }

        .code-block {
            font-family: 'Source Code Pro', 'Courier New', monospace;
            font-size: 11px; background: #1a1a2e; color: #c9d1d9;
            padding: 14px 16px; border-radius: 6px; margin-bottom: 16px;
            white-space: pre-wrap;
        }

        .page-note {
            margin-top: 32px; text-align: center; font-size: 11px;
            color: #999; border-top: 1px solid #e0e0e0; padding-top: 12px;
        }
    </style>
</head>
<body>
    @await Html.PartialAsync("_TypographyPartial", Model)
</body>
</html>
