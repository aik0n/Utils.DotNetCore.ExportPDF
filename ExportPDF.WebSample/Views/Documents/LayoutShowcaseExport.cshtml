@model LayoutShowcaseModel
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env

@{
    Layout = null;
    var bootstrapPath = System.IO.Path.Combine(Env.WebRootPath, "lib", "bootstrap", "dist", "css", "bootstrap.min.css");
    var bootstrapCss = await System.IO.File.ReadAllTextAsync(bootstrapPath);
}

<!DOCTYPE HTML>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <style>@Html.Raw(bootstrapCss)</style>
    <style>
        .watermark { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%) rotate(-45deg); font-size: 90px; font-weight: 900; color: rgba(0,0,0,0.07); pointer-events: none; z-index: 9999; white-space: nowrap; letter-spacing: 8px; }
        .row.g-3 { display: grid !important; grid-template-columns: 1fr 1fr; grid-template-rows: auto 1fr; gap: 1rem; }
        .row.g-3 > .col { display: grid !important; grid-template-rows: subgrid; grid-row: span 2; padding: 0 !important; }
        .row.g-3 > .col > .card { display: grid; grid-template-rows: subgrid; grid-row: span 2; }
    </style>
</head>
<body class="p-5 bg-white">

    @if (Model.ShowWatermark)
    {
        <div class="watermark">@Model.WatermarkText</div>
    }

    @await Html.PartialAsync("_LayoutShowcasePartial", Model)

</body>
</html>
