@model ExportPDF.WebSample.Models.ImageShowcaseModel

<style>
    .img-showcase-wrap {
        --brand:  #10b981;
        --brand2: #059669;
        --ink:    #1f2937;
        --muted:  #6b7280;
        --border: #d1fae5;
        --bg:     #f0fdf4;
        font-family: 'Segoe UI', Arial, sans-serif;
        font-size: 14px;
        color: var(--ink);
    }

    .img-showcase-header {
        background: linear-gradient(90deg, var(--brand), var(--brand2));
        color: #fff;
        padding: 20px 28px;
        border-radius: 8px 8px 0 0;
    }

    .img-showcase-header h1 {
        font-size: 22px;
        font-weight: 700;
        margin: 0 0 4px 0;
    }

    .img-showcase-header p {
        font-size: 13px;
        margin: 0;
        opacity: 0.85;
    }

    .img-showcase-body {
        border: 1px solid var(--border);
        border-top: none;
        border-radius: 0 0 8px 8px;
        background: var(--bg);
        padding: 28px;
    }

    .img-showcase-image-row {
        display: flex;
        justify-content: center;
        gap: 40px;
        margin-bottom: 24px;
    }

    .img-showcase-image-block {
        text-align: center;
    }

    .img-round {
        border-radius: 50%;
        border: 4px solid var(--brand);
        box-shadow: 0 4px 16px rgba(16, 185, 129, 0.25);
        width: 192px;
        height: 192px;
    }

    .img-square {
        border-radius: 8px;
        border: 4px solid var(--brand);
        box-shadow: 0 4px 16px rgba(16, 185, 129, 0.25);
        width: 192px;
        height: 192px;
    }

    .img-showcase-caption {
        margin-top: 10px;
        font-size: 12px;
        color: var(--muted);
        font-style: italic;
    }

    .img-showcase-description {
        background: #fff;
        border-left: 4px solid var(--brand);
        border-radius: 0 6px 6px 0;
        padding: 14px 18px;
        margin-bottom: 24px;
        font-size: 13px;
        line-height: 1.7;
        color: var(--ink);
    }

    .img-showcase-features-heading {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--brand2);
        margin-bottom: 10px;
    }

    .img-showcase-features ul {
        margin: 0;
        padding-left: 20px;
    }

    .img-showcase-features li {
        font-size: 13px;
        line-height: 1.7;
        color: var(--ink);
        margin-bottom: 4px;
    }
</style>

<div class="img-showcase-wrap">
    <div class="img-showcase-header">
        <h1>@Model.Title</h1>
        <p>Base64 data URI image embedding via Chromium / PuppeteerSharp</p>
    </div>
    <div class="img-showcase-body">

        <div class="img-showcase-image-row">
            <div class="img-showcase-image-block">
                <img src="data:@Model.ImageMimeType;base64,@Model.ImageBase64"
                     alt="@Model.Caption"
                     width="192" height="192" class="img-round" />
                <div class="img-showcase-caption">@Model.Caption</div>
            </div>
            <div class="img-showcase-image-block">
                <img src="data:@Model.QrCodeMimeType;base64,@Model.QrCodeBase64"
                     alt="@Model.QrCodeCaption"
                     width="192" height="192" class="img-square" />
                <div class="img-showcase-caption">@Model.QrCodeCaption</div>
            </div>
        </div>

        <div class="img-showcase-description">
            @Model.Description
        </div>

        <div class="img-showcase-features">
            <div class="img-showcase-features-heading">Feature Highlights</div>
            <ul>
                @foreach (var highlight in Model.FeatureHighlights)
                {
                    <li>@highlight</li>
                }
            </ul>
        </div>

    </div>
</div>
