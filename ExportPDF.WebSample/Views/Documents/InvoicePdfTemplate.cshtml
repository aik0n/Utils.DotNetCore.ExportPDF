@model ExportPDF.WebSample.Models.InvoiceModel
@{
    Layout = null;
}
<!DOCTYPE HTML>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <style>
            /* ── Reset & base ───────────────────────────────────────────── */
            *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
            body   { font-family: 'Segoe UI', Arial, sans-serif; font-size: 13px;
                     color: #1a1a2e; background: #fff; padding: 40px 50px; }

            /* ── Header band ────────────────────────────────────────────── */
            .header        { display: flex; justify-content: space-between;
                             border-bottom: 3px solid #4a90d9; padding-bottom: 18px;
                             margin-bottom: 28px; }
            .brand         { font-size: 28px; font-weight: 700; color: #4a90d9;
                             letter-spacing: -0.5px; }
            .invoice-meta  { text-align: right; }
            .invoice-meta h2 { font-size: 22px; color: #4a90d9; margin-bottom: 4px; }
            .invoice-meta p  { font-size: 12px; color: #555; }

            /* ── Party block ────────────────────────────────────────────── */
            .parties       { display: flex; gap: 60px; margin-bottom: 28px; }
            .party-block h4 { font-size: 10px; text-transform: uppercase;
                              letter-spacing: 1px; color: #4a90d9; margin-bottom: 6px; }
            .party-block p  { font-size: 12.5px; line-height: 1.55; color: #333; }

            /* ── Line-items table ───────────────────────────────────────── */
            table          { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
            thead tr       { background: #4a90d9; color: #fff; }
            thead th       { padding: 9px 12px; text-align: left; font-size: 12px;
                             font-weight: 600; letter-spacing: 0.3px; }
            tbody tr:nth-child(even) { background: #f0f6ff; }
            tbody td       { padding: 8px 12px; border-bottom: 1px solid #dde6f0;
                             font-size: 12.5px; }
            .text-right    { text-align: right; }

            /* ── Totals ─────────────────────────────────────────────────── */
            .totals        { width: 280px; margin-left: auto; margin-bottom: 28px; }
            .totals table  { margin-bottom: 0; }
            .totals td     { padding: 5px 10px; font-size: 12.5px; }
            .totals .grand td { font-weight: 700; font-size: 14px;
                                border-top: 2px solid #4a90d9; color: #1a1a2e; }

            /* ── Notes ──────────────────────────────────────────────────── */
            .notes         { background: #f7faff; border-left: 4px solid #4a90d9;
                             padding: 12px 16px; font-size: 12px; color: #444;
                             border-radius: 0 4px 4px 0; }
            .notes strong  { display: block; margin-bottom: 4px; color: #1a1a2e; }

            /* ── Footer ─────────────────────────────────────────────────── */
            .footer        { margin-top: 36px; text-align: center;
                             font-size: 11px; color: #999; border-top: 1px solid #e0e0e0;
                             padding-top: 12px; }
    </style>
</head>
<body>

    <!-- ── Header ──────────────────────────────────────────── -->
    <div class="header">
        <div class="brand">ACME Corp.</div>
        <div class="invoice-meta">
            <h2>INVOICE</h2>
            <p><strong># @Model.InvoiceNumber</strong></p>
            <p>Issued: @Model.IssueDate.ToString("MMMM d, yyyy")</p>
            <p>Due:    @Model.DueDate.ToString("MMMM d, yyyy")</p>
        </div>
    </div>

    <!-- ── Parties ──────────────────────────────────────────── -->
    <div class="parties">
        <div class="party-block">
            <h4>From</h4>
            <p><strong>@Model.BillFrom.Name</strong></p>
            <p>@Model.BillFrom.Address</p>
            <p>@Model.BillFrom.Email</p>
        </div>
        <div class="party-block">
            <h4>Bill To</h4>
            <p><strong>@Model.BillTo.Name</strong></p>
            <p>@Model.BillTo.Address</p>
            <p>@Model.BillTo.Email</p>
        </div>
    </div>

    <!-- ── Line Items ───────────────────────────────────────── -->
    <table>
        <thead>
            <tr>
                <th>Description</th>
                <th class="text-right">Qty</th>
                <th class="text-right">Unit Price</th>
                <th class="text-right">Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Description</td>
                    <td class="text-right">@item.Quantity</td>
                    <td class="text-right">$@item.UnitPrice.ToString("N2")</td>
                    <td class="text-right">$@item.Total.ToString("N2")</td>
                </tr>
            }
        </tbody>
    </table>

    <!-- ── Totals ───────────────────────────────────────────── -->
    <div class="totals">
        <table>
            <tr>
                <td>Subtotal</td>
                <td class="text-right">$@Model.Subtotal.ToString("N2")</td>
            </tr>
            <tr>
                <td>Tax (@((Model.TaxRate * 100).ToString("0"))%)</td>
                <td class="text-right">$@Model.TaxAmount.ToString("N2")</td>
            </tr>
            <tr class="grand">
                <td>Grand Total</td>
                <td class="text-right">$@Model.GrandTotal.ToString("N2")</td>
            </tr>
        </table>
    </div>

    <!-- ── Notes ────────────────────────────────────────────── -->
    @if (!string.IsNullOrWhiteSpace(Model.Notes))
    {
        <div class="notes">
            <strong>Notes</strong>
            @Model.Notes
        </div>
    }

    <!-- ── Footer ───────────────────────────────────────────── -->
    <div class="footer">
        Thank you for your business — ACME Corp. · payments@acme.example.com
    </div>

</body>
</html>
