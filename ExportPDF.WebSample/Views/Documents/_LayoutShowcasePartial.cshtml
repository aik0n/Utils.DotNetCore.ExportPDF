@model LayoutShowcaseModel

<style>
    @@supports (grid-template-rows: subgrid) {
        .card-row-2col {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            grid-template-rows: auto 1fr;
            column-gap: 1rem;
        }

        .card-row-3col {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            grid-template-rows: auto 1fr;
            column-gap: 1rem;
        }

        .card-row-2col > .col,
        .card-row-3col > .col {
            display: contents;
        }

        .card-row-2col .card,
        .card-row-3col .card {
            display: grid;
            grid-template-rows: subgrid;
            grid-row: span 2;
        }
    }
</style>

<div class="position-relative" style="z-index: 1;">

    <h2 class="border-bottom border-primary text-primary fw-bold pb-2 mb-4">@Model.Title</h2>

    <div class="row g-3 mb-4 card-row-2col">
        <div class="col">
            <div class="card h-100">
                <div class="card-header bg-primary text-white text-uppercase small fw-semibold" style="letter-spacing: 1px;">@Model.LeftColumn.Heading</div>
                <div class="card-body bg-light">@Model.LeftColumn.Body</div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100">
                <div class="card-header bg-primary text-white text-uppercase small fw-semibold" style="letter-spacing: 1px;">@Model.RightColumn.Heading</div>
                <div class="card-body bg-light">@Model.RightColumn.Body</div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4 card-row-3col">
        @foreach (var item in Model.ThreeColumns)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-header bg-secondary text-white text-uppercase small fw-semibold" style="letter-spacing: 1px;">@item.Heading</div>
                    <div class="card-body bg-light">@item.Body</div>
                </div>
            </div>
        }
    </div>

    <div class="mb-4">
        <h5 class="mb-3">Overview</h5>
        @foreach (var overviewItem in Model.Overview)
        {
            <p>@overviewItem</p>
        }
    </div>

</div>
