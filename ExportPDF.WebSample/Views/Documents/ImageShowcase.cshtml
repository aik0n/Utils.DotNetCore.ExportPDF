@model ExportPDF.WebSample.Models.ImageShowcaseModel

@{
    ViewData["Title"] = "Image Showcase";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Image Embed Showcase</h1>
        <p class="text-muted mb-0">Demonstrates base64 data URI image embedding in generated PDFs</p>
    </div>
    <form asp-controller="Documents" asp-action="ImageShowcase" method="post">
        <input type="hidden" name="cacheKey" value="@ViewData["CacheKey"]" />
        <button type="submit" class="btn btn-success">&#x2193; Export to PDF</button>
    </form>
</div>

@await Html.PartialAsync("_ImageShowcasePartial", Model)
