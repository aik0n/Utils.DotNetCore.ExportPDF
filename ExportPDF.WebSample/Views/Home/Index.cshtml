@{
    ViewData["Title"] = "PDF Showcases";
}

<h1 class="mb-4">PDF Showcases</h1>
<p class="text-muted mb-4">Explore the PDF export capabilities. Each showcase demonstrates a different document layout and feature set.</p>

<div class="row row-cols-1 row-cols-md-2 g-4">
    <div class="col">
        <a asp-controller="Documents" asp-action="InvoiceShow" class="text-decoration-none">
            <div class="card h-100 showcase-card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Invoice</h5>
                </div>
                <div class="card-body">
                    <p class="card-text">A professional business invoice with line items, subtotals, tax calculation, and payment notes. Demonstrates table layouts and financial formatting.</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col">
        <a asp-controller="Documents" asp-action="LayoutShowcaseShow" class="text-decoration-none">
            <div class="card h-100 showcase-card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Layout Showcase</h5>
                </div>
                <div class="card-body">
                    <p class="card-text">Demonstrates two-column layouts, CSS tab panels, rounded corners and borders, a fixed-position watermark, and a letterhead background image.</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col">
        <a asp-controller="Documents" asp-action="TypographyShow" class="text-decoration-none">
            <div class="card h-100 showcase-card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Typography &amp; Fonts</h5>
                </div>
                <div class="card-body">
                    <p class="card-text">Showcases custom fonts via <code>@@font-face</code>, Unicode and special characters, long text overflow handling, and <code>@@media print</code> CSS rules.</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col">
        <a asp-controller="Documents" asp-action="PartialViewsShow" class="text-decoration-none">
            <div class="card h-100 showcase-card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Partial Views &amp; Composition</h5>
                </div>
                <div class="card-body">
                    <p class="card-text">Illustrates reusable header and footer components, conditional content blocks, multiple section types, and landscape page orientation.</p>
                </div>
            </div>
        </a>
    </div>
</div>

<style>
    .showcase-card {
        cursor: pointer;
        transition: box-shadow 0.2s ease, transform 0.2s ease;
    }

    .showcase-card:hover {
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
        transform: translateY(-2px);
    }
</style>
