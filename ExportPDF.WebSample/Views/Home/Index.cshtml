@{
    ViewData["Title"] = "PDF Showcases";
}

@section Styles {
    <link rel="stylesheet" href="~/css/showcase-cards.css" asp-append-version="true" />
}

<h1 class="mb-2">PDF Showcases</h1>
<p class="text-muted mb-4">Explore the PDF export capabilities. Each showcase demonstrates a different document layout and feature set.</p>

<div class="row row-cols-1 row-cols-md-2 g-4">

    <div class="col">
        <a asp-controller="Documents" asp-action="InvoiceShow" class="text-decoration-none">
            <div class="ac" style="--c1:#6366f1;--c2:#8b5cf6">
                <div class="ac-stripe"></div>
                <div class="ac-body">
                    <div class="ac-header">
                        <div class="ac-icon" style="background:linear-gradient(135deg,#6366f1,#8b5cf6)">📄</div>
                        <h5 class="ac-title">Invoice</h5>
                    </div>
                    <p class="ac-text">A professional business invoice with line items, subtotals, tax calculation, and payment notes. Demonstrates table layouts and financial formatting.</p>
                    <span class="ac-tag" style="color:#6366f1">Finance · Tables</span>
                </div>
            </div>
        </a>
    </div>

    <div class="col">
        <a asp-controller="Documents" asp-action="LayoutShowcaseShow" class="text-decoration-none">
            <div class="ac" style="--c1:#0ea5e9;--c2:#06b6d4">
                <div class="ac-stripe"></div>
                <div class="ac-body">
                    <div class="ac-header">
                        <div class="ac-icon" style="background:linear-gradient(135deg,#0ea5e9,#06b6d4)">🗂️</div>
                        <h5 class="ac-title">Layout Showcase</h5>
                    </div>
                    <p class="ac-text">Demonstrates two-column layouts, CSS tab panels, rounded corners and borders, a fixed-position watermark, and a letterhead background image.</p>
                    <span class="ac-tag" style="color:#0ea5e9">Layout · CSS</span>
                </div>
            </div>
        </a>
    </div>

    <div class="col">
        <a asp-controller="Documents" asp-action="TypographyShow" class="text-decoration-none">
            <div class="ac" style="--c1:#f59e0b;--c2:#ef4444">
                <div class="ac-stripe"></div>
                <div class="ac-body">
                    <div class="ac-header">
                        <div class="ac-icon" style="background:linear-gradient(135deg,#f59e0b,#ef4444)">🔤</div>
                        <h5 class="ac-title">Typography &amp; Fonts</h5>
                    </div>
                    <p class="ac-text">Showcases custom fonts via <code>@@font-face</code>, Unicode and special characters, long text overflow handling, and <code>@@media print</code> CSS rules.</p>
                    <span class="ac-tag" style="color:#f59e0b">Fonts · Unicode</span>
                </div>
            </div>
        </a>
    </div>

    <div class="col">
        <a asp-controller="Documents" asp-action="PartialViewsShow" class="text-decoration-none">
            <div class="ac" style="--c1:#10b981;--c2:#059669">
                <div class="ac-stripe"></div>
                <div class="ac-body">
                    <div class="ac-header">
                        <div class="ac-icon" style="background:linear-gradient(135deg,#10b981,#059669)">🧩</div>
                        <h5 class="ac-title">Partial Views &amp; Composition</h5>
                    </div>
                    <p class="ac-text">Illustrates reusable header and footer components, conditional content blocks, multiple section types, and landscape page orientation.</p>
                    <span class="ac-tag" style="color:#10b981">Components · Landscape</span>
                </div>
            </div>
        </a>
    </div>

</div>

