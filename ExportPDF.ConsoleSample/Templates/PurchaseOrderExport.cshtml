@model ExportPDF.ConsoleSample.Models.PurchaseOrderModel

@{
    Layout = null;
}

<!DOCTYPE HTML>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Purchase Order @Model.PurchaseOrderNumber</title>
    <style>
        * { margin: 0; padding: 0; }
        body { font-family: Arial, sans-serif; font-size: 11pt; color: #222; padding: 20px; }

        h1 { font-size: 20pt; color: #1a3a5c; margin-bottom: 4px; }
        h2 { font-size: 11pt; color: #1a3a5c; margin-bottom: 6px; border-bottom: 1px solid #ccc; padding-bottom: 3px; }

        /* Header */
        .header { margin-bottom: 16px; }
        .header-title { font-size: 22pt; font-weight: bold; color: #1a3a5c; }
        .header-subtitle { font-size: 10pt; color: #666; }

        /* Meta-row label/value styles */
        .meta-label { font-size: 8pt; color: #888; text-transform: uppercase; margin-bottom: 2px; }
        .meta-value { font-size: 10pt; font-weight: bold; color: #222; }

        /* Line items table — scoped so layout tables are unaffected */
        .items-table { width: 100%; border-collapse: collapse; margin-bottom: 12px; }
        .items-table th { background-color: #1a3a5c; color: #fff; text-align: left; padding: 6px 8px; font-size: 9.5pt; }
        .items-table td { padding: 5px 8px; font-size: 10pt; border-bottom: 1px solid #e0e0e0; }
        .items-table tr.alt td { background-color: #f9f9f9; }
        .items-table td.num { text-align: right; }
        .items-table th.num { text-align: right; }

        /* Totals inner table */
        .totals-table { width: 100%; border-collapse: collapse; border: 1px solid #d0d0d0; }
        .totals-table td { padding: 5px 10px; font-size: 10pt; border-bottom: none; }
        .totals-num { text-align: right; font-weight: bold; }
        .totals-table tr.grand td { background-color: #1a3a5c; color: #fff; font-size: 11pt; }

        /* Notes / footer */
        .notes { padding-top: 8px; font-size: 9.5pt; color: #444; }
        .notes strong { color: #222; }

        .footer {
            margin-top: 20px;
            text-align: center;
            font-size: 8pt;
            color: #aaa;
            padding: 6px 20px;
            border-top: 1px solid #e0e0e0;
        }
    </style>
</head>
<body>

    <!-- Header -->
    <div class="header">
        <div class="header-title">PURCHASE ORDER</div>
        <div class="header-subtitle">@Model.PurchaseOrderNumber</div>
    </div>

    <!-- PO Metadata row: 4-column table replaces float divs -->
    <table width="100%" cellpadding="0" cellspacing="0"
           style="border: 1px solid #d0d0d0; background-color: #f5f7fa; margin-bottom: 16px;">
        <tr>
            <td width="25%" style="padding: 8px 10px; border-right: 1px solid #d0d0d0; vertical-align: top;">
                <div class="meta-label">PO Number</div>
                <div class="meta-value">@Model.PurchaseOrderNumber</div>
            </td>
            <td width="25%" style="padding: 8px 10px; border-right: 1px solid #d0d0d0; vertical-align: top;">
                <div class="meta-label">Order Date</div>
                <div class="meta-value">@Model.OrderDate.ToString("MMM dd, yyyy")</div>
            </td>
            <td width="25%" style="padding: 8px 10px; border-right: 1px solid #d0d0d0; vertical-align: top;">
                <div class="meta-label">Required By</div>
                <div class="meta-value">@Model.RequiredDate.ToString("MMM dd, yyyy")</div>
            </td>
            <td width="25%" style="padding: 8px 10px; vertical-align: top;">
                <div class="meta-label">Payment / Shipping</div>
                <div class="meta-value">@Model.PaymentTerms &nbsp;|&nbsp; @Model.ShippingMethod</div>
            </td>
        </tr>
    </table>

    <!-- Vendor / Ship-To: 2-column table replaces float columns -->
    <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 14px;">
        <tr>
            <td width="48%" style="vertical-align: top; padding-right: 16px;">
                <h2>Vendor</h2>
                <p style="margin: 2px 0; font-size: 10pt;"><strong>@Model.Vendor.Name</strong></p>
                <p style="margin: 2px 0; font-size: 10pt;">@Model.Vendor.Address</p>
                <p style="margin: 2px 0; font-size: 10pt;">@Model.Vendor.City</p>
                <p style="margin: 2px 0; font-size: 10pt;">@Model.Vendor.Phone</p>
                <p style="margin: 2px 0; font-size: 10pt;">@Model.Vendor.Email</p>
                <p style="margin: 2px 0; font-size: 10pt;">Attn: @Model.Vendor.ContactPerson</p>
            </td>
            <td width="48%" style="vertical-align: top;">
                <h2>Ship To</h2>
                <p style="margin: 2px 0; font-size: 10pt;"><strong>@Model.ShipTo.CompanyName</strong></p>
                <p style="margin: 2px 0; font-size: 10pt;">@Model.ShipTo.Address</p>
                <p style="margin: 2px 0; font-size: 10pt;">@Model.ShipTo.City</p>
                <p style="margin: 2px 0; font-size: 10pt;">@Model.ShipTo.Phone</p>
                <p style="margin: 2px 0; font-size: 10pt;">Attn: @Model.ShipTo.ContactPerson</p>
            </td>
        </tr>
    </table>

    <!-- Line Items -->
    <h2>Line Items</h2>
    <table class="items-table">
        <thead>
            <tr>
                <th style="width:90px;">Item Code</th>
                <th>Description</th>
                <th style="width:45px;" class="num">Qty</th>
                <th style="width:50px;">Unit</th>
                <th style="width:80px;" class="num">Unit Price</th>
                <th style="width:90px;" class="num">Total</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Items.Count; i++)
            {
                var item = Model.Items[i];
                var rowClass = i % 2 == 1 ? "alt" : "";
                <tr class="@rowClass">
                    <td>@item.ItemCode</td>
                    <td>@item.Description</td>
                    <td class="num">@item.Quantity</td>
                    <td>@item.Unit</td>
                    <td class="num">$@item.UnitPrice.ToString("N2")</td>
                    <td class="num">$@item.Total.ToString("N2")</td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Totals right-aligned: layout table with empty left cell -->
    <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 16px;">
        <tr>
            <td style="vertical-align: top;"></td>
            <td width="260" style="vertical-align: top;">
                <table class="totals-table" cellpadding="0" cellspacing="0">
                    <tr>
                        <td>Subtotal</td>
                        <td class="totals-num">$@Model.Subtotal.ToString("N2")</td>
                    </tr>
                    <tr>
                        <td>Tax (@((Model.TaxRate * 100).ToString("0"))%)</td>
                        <td class="totals-num">$@Model.TaxAmount.ToString("N2")</td>
                    </tr>
                    <tr class="grand">
                        <td>Grand Total</td>
                        <td class="totals-num">$@Model.GrandTotal.ToString("N2")</td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>

    <!-- Notes -->
    <div class="notes">
        <strong>Notes:</strong> @Model.Notes
    </div>

    <!-- Footer -->
    <div class="footer">
        This purchase order is subject to the terms and conditions agreed upon between the parties.
    </div>

</body>
</html>
